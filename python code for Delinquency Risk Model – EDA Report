import pandas as pd
import numpy as np

# Suppress the downcasting warning
pd.set_option('future.no_silent_downcasting', True)

def perform_feature_engineering(input_file, output_file):
    # Load the data from your specific folder
    df = pd.read_csv(input_file)

    # 1. Date conversion
    date_cols = ['date_activ', 'date_end', 'date_modif_prod', 'date_renewal']
    for col in date_cols:
        df[col] = pd.to_datetime(df[col])

    # 2. Extract Date-based features
    ref_date = df['date_end'].max()
    df['tenure_months'] = ((ref_date - df['date_activ']).dt.days / 30.44).astype(int)
    df['months_to_end'] = ((df['date_end'] - ref_date).dt.days / 30.44).astype(int)
    df['months_since_modif'] = ((ref_date - df['date_modif_prod']).dt.days / 30.44).astype(int)
    df['months_since_renewal'] = ((ref_date - df['date_renewal']).dt.days / 30.44).astype(int)

    # 3. Consumption based features
    df['total_cons_12m'] = df['cons_12m'] + df['cons_gas_12m']
    df['cons_last_month_ratio'] = df['cons_last_month'] / (df['cons_12m'] / 12 + 1)

    # 4. Price based features
    df['diff_energy_off_peak_peak'] = df['forecast_price_energy_off_peak'] - df['forecast_price_energy_peak']
    df['diff_energy_off_peak_pow'] = df['forecast_price_energy_off_peak'] - df['forecast_price_pow_off_peak']

    # 5. Transform categorical variables (Map used to avoid the warning)
    df['has_gas'] = df['has_gas'].map({'t': 1, 'f': 0}).astype(int)
    df = pd.get_dummies(df, columns=['channel_sales', 'origin_up'], prefix=['channel', 'origin'])

    # 6. Removing redundant columns
    cols_to_drop = ['id', 'date_activ', 'date_end', 'date_modif_prod', 'date_renewal', 'margin_gross_pow_ele']
    df_engineered = df.drop(columns=cols_to_drop)

    # Save results (This will save 'engineered_features.csv' in the same folder as your script)
    df_engineered.to_csv(output_file, index=False)
    print(f"Success! Engineered file saved as: {output_file}")

if __name__ == "__main__":
    # Use 'r' before the path to handle Windows backslashes correctly
    my_input_path = r"C:\Users\anjit\Downloads\clean_data_after_eda.csv"
    my_output_name = "engineered_features.csv"
    
    perform_feature_engineering(my_input_path, my_output_name)
